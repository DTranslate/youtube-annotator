{
  "compilerOptions": {
    "baseUrl": "./src",
    "paths": {
      "@view/*": ["view/*"],
      "@modal/*": ["modal/*"],
      "@constants": ["constants/constants"],
      "@hotkeys/*": ["hotkeys/*"],
      "@settings/*": ["settings/*"],
      "@types/*": ["types/*"],
      "@util/*": ["src/utils/*"],
      "@util": ["src/util"],
      "@ui/*": ["ui/*"]
    },
    "module": "ESNext",
    "target": "ES6",
    "lib": ["DOM", "ES6"],
    "allowJs": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "moduleResolution": "node",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "importHelpers": true,
    "isolatedModules": true,
    "inlineSourceMap": true,
    "inlineSources": true
  },
  "exclude": [
    "node_modules",
    "docs",
    "esbuild.config.mjs",
    "main.js",
    "version-bump.mjs"
  ]
}
